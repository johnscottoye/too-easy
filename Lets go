// PLACEHOLDER IMAGE COMPONENT
// To use real images, replace <PlaceholderImage> with:
// <img src={image.src} alt={image.label} style={{width:"100%",height:"100%",objectFit:"cover"}} />
// and add a `src` field to each image in the data arrays above.
// ============================================================

const palette = [
  ["#d4e8f0", "#8bb8cc"],
  ["#f0e6d4", "#ccaa88"],
  ["#d4f0e8", "#88ccaa"],
  ["#e8d4f0", "#bb88cc"],
  ["#f0f0e8", "#c8c8b8"],
  ["#f0ddd4", "#ccaa9a"],
];

function PlaceholderImage({ label, aspect = "landscape", index = 0, bw = false }) {
  const [bg, fg] = palette[index % palette.length];
  return (
    <div style={{
      width: "100%", height: "100%",
      background: bw ? "#d8d8d0" : bg,
      display: "flex", flexDirection: "column",
      alignItems: "center", justifyContent: "center",
      gap: "6px",
      filter: bw ? "grayscale(1)" : "none",
    }}>
      <span style={{
        fontSize: "11px",
        fontFamily: "'DM Mono', monospace",
        color: bw ? "#777" : fg,
        letterSpacing: "0.05em",
        textAlign: "center",
        padding: "0 12px",
        lineHeight: 1.4,
      }}>
        {label}
      </span>
    </div>
  );
}

// ============================================================
// LIGHTBOX MODAL
// ============================================================

function LightboxModal({ images, startIndex, onClose, bw = false }) {
  const [current, setCurrent] = useState(startIndex);

  const prev = useCallback(() => setCurrent(i => (i - 1 + images.length) % images.length), [images.length]);
  const next = useCallback(() => setCurrent(i => (i + 1) % images.length), [images.length]);

  useEffect(() => {
    const handler = (e) => {
      if (e.key === "Escape") onClose();
      if (e.key === "ArrowLeft") prev();
      if (e.key === "ArrowRight") next();
    };
    window.addEventListener("keydown", handler);
    return () => window.removeEventListener("keydown", handler);
  }, [onClose, prev, next]);

  const img = images[current];

  return (
    <div
      onClick={onClose}
      style={{
        position: "fixed", inset: 0, background: "rgba(10,10,10,0.96)",
        zIndex: 1000, display: "flex", flexDirection: "column",
        alignItems: "center", justifyContent: "center",
      }}
    >
      <button
        onClick={onClose}
        style={{ position: "absolute", top: 24, right: 28, background: "none", border: "none", color: "#fff", fontSize: 28, cursor: "pointer", opacity: 0.7, lineHeight: 1 }}
        aria-label="Close"
      >×</button>

      <div
        onClick={e => e.stopPropagation()}
        style={{ width: "min(860px, 92vw)", maxHeight: "80vh", display: "flex", flexDirection: "column" }}
      >
        <div style={{
          width: "100%",
          aspectRatio: img.aspect === "portrait" ? "3/4" : "3/2",
          maxHeight: "70vh",
          background: "#1a1a1a",
          borderRadius: 4,
          overflow: "hidden",
        }}>
          <PlaceholderImage label={img.label} aspect={img.aspect} index={img.id} bw={bw} />
        </div>

        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "14px 2px 0" }}>
          <div>
            <p style={{ margin: 0, color: "#fff", fontSize: 14, fontFamily: "'Cormorant Garamond', Georgia, serif", fontStyle: "italic" }}>{img.label}</p>
            {img.location && (
              <p style={{ margin: "2px 0 0", color: "rgba(255,255,255,0.45)", fontSize: 12, fontFamily: "'DM Mono', monospace", letterSpacing: "0.04em" }}>
                {img.location}{img.year ? ` — ${img.year}` : ""}{img.camera ? ` — ${img.camera}` : ""}
              </p>
            )}
          </div>
          <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
            <button onClick={prev} style={{ background: "rgba(255,255,255,0.08)", border: "1px solid rgba(255,255,255,0.15)", color: "#fff", width: 38, height: 38, borderRadius: 4, cursor: "pointer", fontSize: 16 }}>←</button>
            <span style={{ color: "rgba(255,255,255,0.3)", fontSize: 12, minWidth: 40, textAlign: "center", fontFamily: "'DM Mono', monospace" }}>
              {current + 1} / {images.length}
            </span>
            <button onClick={next} style={{ background: "rgba(255,255,255,0.08)", border: "1px solid rgba(255,255,255,0.15)", color: "#fff", width: 38, height: 38, borderRadius: 4, cursor: "pointer", fontSize: 16 }}>→</button>
          </div>
        </div>
      </div>
    </div>
  );
}

