function Header({ page, setPage }) {
  const [scrolled, setScrolled] = useState(false);

  useEffect(() => {
    const handler = () => setScrolled(window.scrollY > 40);
    window.addEventListener("scroll", handler);
    return () => window.removeEventListener("scroll", handler);
  }, []);

  const nav = (p) => { setPage(p); window.scrollTo(0, 0); };

  return (
    <header style={{
      position: "fixed", top: 0, left: 0, right: 0, zIndex: 100,
      background: scrolled ? "rgba(254,254,252,0.94)" : "transparent",
      backdropFilter: scrolled ? "blur(12px)" : "none",
      borderBottom: scrolled ? "1px solid rgba(0,0,0,0.06)" : "none",
      transition: "all 0.3s ease",
      padding: "0 32px",
    }}>
      <div style={{ maxWidth: 1200, margin: "0 auto", height: 64, display: "flex", alignItems: "center", justifyContent: "space-between" }}>
        <button onClick={() => nav("home")} style={{ background: "none", border: "none", cursor: "pointer", padding: 0 }}>
          <span style={{
            fontFamily: "'Cormorant Garamond', Georgia, serif",
            fontSize: 22, fontWeight: 600,
            color: page === "home" && !scrolled ? "#fff" : "#111",
            letterSpacing: "0.02em", transition: "color 0.3s",
          }}>Too Easy</span>
        </button>
        <nav style={{ display: "flex", gap: 36, alignItems: "center" }}>
          {NAV_LINKS.map(l => (
            <button
              key={l.page}
              onClick={() => nav(l.page)}
              style={{
                background: "none", border: "none", cursor: "pointer",
                fontFamily: "'DM Mono', monospace", fontSize: 12,
                letterSpacing: "0.08em",
                color: page === "home" && !scrolled ? "rgba(255,255,255,0.85)" : "#555",
                textTransform: "uppercase", padding: 0,
                borderBottom: page === l.page ? "1px solid currentColor" : "1px solid transparent",
                transition: "color 0.2s",
              }}
            >
              {l.label}
            </button>
          ))}
        </nav>
      </div>
    </header>
  );
}

