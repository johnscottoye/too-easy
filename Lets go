export default function App() {
  const [page, setPage] = useState("home");
  const [galleryId, setGalleryId] = useState(null);
  const [albumId, setAlbumId] = useState(null);

  const renderPage = () => {
    switch (page) {
      case "home":          return <HomePage setPage={setPage} setGalleryId={setGalleryId} setAlbumId={setAlbumId} />;
      case "galleries":     return <GalleriesPage setPage={setPage} setGalleryId={setGalleryId} />;
      case "gallery":       return <GalleryPage galleryId={galleryId} setPage={setPage} />;
      case "private":       return <PrivatePage setPage={setPage} setAlbumId={setAlbumId} />;
      case "private-album": return <PrivateAlbumPage albumId={albumId} setPage={setPage} />;
      case "about":         return <AboutPage setPage={setPage} />;
      case "contact":       return <ContactPage />;
      default:              return null;
    }
  };

  return (
    <>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Mono:wght@400&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #fefefe; color: #111; -webkit-font-smoothing: antialiased; }
        button:focus-visible { outline: 2px solid #111; outline-offset: 2px; }
      `}</style>
      <Header page={page} setPage={setPage} />
      <main style={{ minHeight: "100vh" }}>{renderPage()}</main>
      <Footer setPage={setPage} />
    </>
  );
}
